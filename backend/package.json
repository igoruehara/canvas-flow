{
  "name": "canvas-flow-backend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "migrate:flow-versions": "ts-node -r tsconfig-paths/register src/scripts/migrate-canvas-flow-versions.ts",
    "migrate:mcp-oauth-user-scope": "ts-node -r tsconfig-paths/register src/scripts/migrate-mcp-oauth-user-scope.ts",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "deploy": "serverless deploy"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/client-sqs": "^3.1048.0",
    "@aws-sdk/credential-provider-node": "^3.972.47",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "@azure/storage-blob": "^12.31.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.3.3",
    "@langchain/langgraph-checkpoint-mongodb": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@smithy/signature-v4": "^5.4.5",
    "@zilliz/milvus2-sdk-node": "2.6.11",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "docx": "^9.7.1",
    "docxtemplater": "^3.68.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "mammoth": "^1.12.0",
    "mongoose": "^8.8.3",
    "openai": "^4.89.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pizzip": "^3.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.1",
    "rimraf": "^6.1.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
