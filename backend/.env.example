# ============================================================
# Canvas Flow Backend - .env.example
# ============================================================
# Regras:
# - REQUIRED: necessario para subir o backend com seguranca minima.
# - REQUIRED EM PRODUCAO: necessario quando publicar em ambiente real.
# - CONDICIONAL: necessario apenas quando a feature indicada estiver ativa.
# - OPCIONAL: tem default no codigo ou pode ser configurado pela tela de Provedores.

# ============================================================
# REQUIRED - Base do backend
# ============================================================
PORT=3333
NODE_ENV=development
TZ=America/Sao_Paulo
MONGO_DB_CONNECTION_STRING=mongodb://127.0.0.1:27017/canvas_flow

# Dominios permitidos para acessar a API. Em producao, use somente os dominios reais.
CORS_ORIGINS=http://localhost:5177,http://localhost:5173,http://localhost:3000

# Limite global para JSON/urlencoded. Uploads de arquivo usam limites proprios do multer.
REQUEST_BODY_LIMIT=2mb

# Em producao, deixe false salvo se quiser publicar /docs explicitamente.
ENABLE_SWAGGER=true

# Quando true, avisos de hardening em NODE_ENV=production tambem bloqueiam o boot.
CANVAS_FLOW_STRICT_PRODUCTION=false

# ============================================================
# REQUIRED EM PRODUCAO - Seguranca
# ============================================================
# Token master usado por endpoints administrativos e validacao x-canvas-flow-token/x-api-key.
# Gere um valor forte. Exemplo PowerShell:
# [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Max 256 }))
CANVAS_FLOW_API_TOKEN=

# Se CANVAS_FLOW_LOGIN=true, esta chave assina os JWTs.
# Use valor forte e diferente do CANVAS_FLOW_API_TOKEN.
CANVAS_FLOW_JWT_SECRET=

# ============================================================
# CONDICIONAL - Login multiusuario/multiorg
# ============================================================
CANVAS_FLOW_LOGIN=false
CANVAS_FLOW_LOGIN_TTL_HOURS=24

# ============================================================
# CONDICIONAL - Deploy Serverless/Lambda via SSM
# ============================================================
# Prefixo base no AWS SSM Parameter Store.
# Exemplo de parametro: /canvas-flow/dev/CANVAS_FLOW_API_TOKEN
CANVAS_FLOW_SSM_PREFIX=/canvas-flow/dev
LOG_IS_LAMBDA=false
AWS_REGION=us-east-1

# URL publica da API, usada para montar callbacks quando necessario.
# Em producao na AWS, use a Lambda Function URL gerada pelo deploy.
# Tambem e usada para montar links assinados de anexos do WhatsApp Flow.
# Exemplo: https://abcxyz.lambda-url.us-east-1.on.aws
CANVAS_FLOW_PUBLIC_URL=http://localhost:3333
# Alternativas aceitas pelo codigo:
CANVAS_FLOW_API_PUBLIC_URL=
PUBLIC_API_URL=
APP_URL=

# ============================================================
# CONDICIONAL - Documentos originais e artefatos gerados
# ============================================================
# Local para desenvolvimento. Em AWS/Lambda use s3.
CANVAS_FLOW_FILES_STORAGE=local
CANVAS_FLOW_FILES_LOCAL_DIR=./tmp/canvas-flow-documents
CANVAS_FLOW_FILES_S3_BUCKET=
CANVAS_FLOW_FILES_S3_REGION=us-east-1
# Links S3 assinados para download. Maximo aplicado no codigo: 24 horas.
CANVAS_FLOW_FILES_DOWNLOAD_TTL_SECONDS=900

# ============================================================
# CONDICIONAL - Figma remote MCP OAuth
# ============================================================
# Use apenas quando a Figma aprovar/fornecer um cliente OAuth MCP.
# Sem isso, o Figma remoto pode retornar 403 no registro OAuth do cliente.
FIGMA_MCP_OAUTH_CLIENT_ID=
FIGMA_MCP_OAUTH_CLIENT_SECRET=
FIGMA_MCP_OAUTH_TOKEN_AUTH_METHOD=client_secret_post

# Proxy seguro para anexos do WhatsApp Flow.
# As URLs lookaside.fbsbx.com da Meta exigem Authorization; o Canvas gera
# uma URL propria assinada e baixa a midia no backend sem expor token.
# Em producao, use uma chave forte ou deixe igual ao CANVAS_FLOW_JWT_SECRET.
CANVAS_FLOW_MEDIA_PROXY_SECRET=
# Tempo de validade dos links assinados de midia. Maximo aplicado no codigo: 7 dias.
CANVAS_FLOW_MEDIA_PROXY_TTL_SECONDS=86400

# ============================================================
# CONDICIONAL - SQS async transitions
# ============================================================
# Ative quando quiser processar mensagens via SQS/Lambda.
CANVAS_FLOW_SQS=false
# Em deploy Serverless/Lambda, a fila Standard e a DLQ sao criadas pelo stack
# e estes valores sao injetados automaticamente no ambiente da Lambda.
# Preencha manualmente apenas para uso local ou fila externa.
CANVAS_FLOW_SQS_QUEUE_URL=
CANVAS_FLOW_SQS_QUEUE_ARN=
CANVAS_FLOW_SQS_REGION=us-east-1

# Trigger Lambda por SQS no serverless.yaml.
# No deploy Serverless o default e true; desligue apenas se quiser pausar o consumer.
CANVAS_FLOW_SQS_TRIGGER_ENABLED=true
CANVAS_FLOW_SQS_BATCH_SIZE=10
CANVAS_FLOW_SQS_BATCH_WINDOW_SECONDS=2

# Controle interno do consumer e da ordem por conversationId.
CANVAS_FLOW_SQS_JOB_TTL_HOURS=24
CANVAS_FLOW_SQS_CONSUMER_CONCURRENCY=10
CANVAS_FLOW_SQS_CONVERSATION_LOCK_TTL_MS=900000

# Rate limit e deduplicacao para evitar abuso/reprocessamento.
CANVAS_FLOW_RATE_LIMIT_ENABLED=true
CANVAS_FLOW_RATE_LIMIT_WINDOW_MS=60000
CANVAS_FLOW_RATE_LIMIT_PER_MINUTE=600
CANVAS_FLOW_RATE_LIMIT_WEBWIDGET_PER_MINUTE=300
CANVAS_FLOW_RATE_LIMIT_WHATSAPP_PER_MINUTE=600
CANVAS_FLOW_RATE_LIMIT_API_PER_MINUTE=600
CANVAS_FLOW_MESSAGE_DEDUPE_TTL_HOURS=24

# Checkpoints LangGraph persistidos no Mongo para retomar cada conversa.
# Mantenha o TTL acima da maior janela esperada para aprovacoes humanas.
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_NAMESPACE=canvas-flow-runtime-v1
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_COLLECTION=canvas_langgraph_checkpoints
CANVAS_FLOW_LANGGRAPH_WRITES_COLLECTION=canvas_langgraph_checkpoint_writes
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_TTL_HOURS=720
# Repete a criacao dos indices quando houver falha transitoria de rede no Mongo.
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_INDEX_RETRY_ATTEMPTS=3
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_INDEX_RETRY_DELAY_MS=250

# Alias aceito pelo codigo para fila SQS.
SQS_QUEUE_URL=

# ============================================================
# OPCIONAL - Performance e concorrencia
# ============================================================
# Limita quantos nos do mesmo lote podem rodar em paralelo por request.
CANVAS_FLOW_MAX_PARALLEL_NODES=50

# Limita quantas vezes o mesmo no pode ser visitado no mesmo turno/request.
CANVAS_FLOW_MAX_STEP_VISITS=10

# Cache curto das configuracoes salvas em Acoes > Provedores.
CANVAS_FLOW_PROVIDER_CACHE_MS=10000

# Timeouts de conexao Mongo.
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
MONGO_CONNECT_TIMEOUT_MS=8000

# Cron interno. Em Lambda, normalmente fica false.
CANVAS_FLOW_CRON_AUTORUN=true
CANVAS_FLOW_CRON_SCAN_MS=30000

# Batch HTTP usado por componentes/API polling.
HTTP_BATCH_TIMEOUT_MS=120000
HTTP_BATCH_MAX_REQUESTS=10
HTTP_BATCH_POLLING_MAX_ATTEMPTS=20
HTTP_BATCH_POLLING_MAX_INTERVAL_SECONDS=60
HTTP_BATCH_POLLING_HISTORY_LIMIT=8

# ============================================================
# OPCIONAL - Provedores LLM/RAG como fallback de ambiente
# ============================================================
# Preferencia atual: configurar pela tela Acoes > Provedores.
# Estas variaveis ficam como fallback/boot local.

# OpenAI provider: openai, azure, azure_openai, azure-openai, gemini, claude, grok ou bedrock.
OPENAI_PROVIDER=openai
LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_OCR_MODEL=gpt-4o

# Azure OpenAI.
AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_BASE_PATH=
AZURE_OPENAI_API_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_API_CHAT_MODEL_NAME=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MODEL_NAME=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=
AZURE_OPENAI_MODEL_NAME_EMB=
AZURE_OPENAI_OCR_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072

# Gemini.
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_MODEL=gemini-3.5-flash

# Claude / Anthropic.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
CLAUDE_CHAT_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# Grok / xAI.
XAI_API_KEY=
GROK_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
GROK_BASE_URL=https://api.x.ai/v1
GROK_CHAT_MODEL=grok-2-latest
XAI_MODEL=grok-2-latest

# Bedrock OpenAI-compatible endpoint.
BEDROCK_API_KEY=
BEDROCK_BASE_URL=
BEDROCK_REGION=us-east-1
BEDROCK_CHAT_MODEL=anthropic.claude-sonnet-4-6
BEDROCK_MODEL=anthropic.claude-sonnet-4-6

# ============================================================
# OPCIONAL - Milvus RAG
# ============================================================
MILVUS_ADDRESS=
MILVUS_TOKEN=
MILVUS_USERNAME=
MILVUS_PASSWORD=
COLLECTION_NAME=canvas_flow_docs
RAG_VECTOR_PROVIDER=milvus

# ============================================================
# OPCIONAL - Azure Blob Storage
# ============================================================
BLOB_STRING_CONNECTION=
BLOB_CONTAINER_NAME=

# Aliases aceitos pelo codigo.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=

# ============================================================
# OPCIONAL - Azure AI Search
# ============================================================
AZURE_SEARCH_API_BASE_PATH=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_API_VERSION=2024-07-01

# ============================================================
# OPCIONAL - MongoDB operacional do componente MongoDB
# ============================================================
# Vazio usa MONGO_DB_CONNECTION_STRING.
MONGO_COMPONENT_CONNECTION_STRING=
MONGO_COMPONENT_DB_NAME=

# ============================================================
# OPCIONAL - Web Widget
# ============================================================
CANVAS_FLOW_WIDGET_PRIMARY_COLOR=#0f6bff
CANVAS_FLOW_WIDGET_ACCENT_COLOR=#00b37e
CANVAS_FLOW_WIDGET_ASSISTANT_NAME=Assistente IA
CANVAS_FLOW_WIDGET_SUBTITLE=Online agora
CANVAS_FLOW_WIDGET_WELCOME_MESSAGE=Ola! Como posso ajudar?
CANVAS_FLOW_WIDGET_PLACEHOLDER=Digite sua mensagem
CANVAS_FLOW_WIDGET_BUBBLE_LABEL=Precisa de ajuda?
CANVAS_FLOW_WIDGET_AVATAR_TEXT=IA
CANVAS_FLOW_WIDGET_OPEN_BY_DEFAULT=false
CANVAS_FLOW_WIDGET_POSITION=right

# ============================================================
# OPCIONAL - WhatsApp API Oficial Meta fallback
# ============================================================
# Normalmente estas credenciais ficam na configuracao do canal/fluxo.
# Modos de onboarding:
# - manual: informe WABA/Phone Number ID/access token ja existentes.
# - embeddedSignup: self-hosted/open source com app Meta proprio do usuario.
# - coexistence: preset Sinergy gerenciado; exige dominio autorizado no app Meta
#   da Sinergy ou uma URL fixa de onboarding da Sinergy.
WHATSAPP_PROVIDER=meta
WHATSAPP_DELIVERY_MODE=provider
WHATSAPP_AUTO_REPLY=true
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WABA_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v20.0
WHATSAPP_ONBOARDING_MODE=manual
WHATSAPP_COEXISTENCE_ENABLED=false
WHATSAPP_SYNC_MESSAGE_ECHOES=true
WHATSAPP_SYNC_HISTORY=false
WHATSAPP_EMBEDDED_SIGNUP_APP_ID=617497366521622
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=1952866105586018
WHATSAPP_EMBEDDED_SIGNUP_APP_SECRET=
WHATSAPP_EMBEDDED_SIGNUP_SOLUTION_ID=
WHATSAPP_EMBEDDED_SIGNUP_FEATURE_TYPE=
WHATSAPP_EMBEDDED_SIGNUP_SESSION_INFO_VERSION=3
WHATSAPP_EMBEDDED_SIGNUP_VERSION=v3

# ============================================================
# OPCIONAL - Sinch relay
# ============================================================
# URL da API Sinch usada por "Enviar via API Sinch e retornar payload".
# Credenciais do cliente ficam na configuracao WhatsApp/Sinch do fluxo.
BLIP_CONTRACT_ID=
BLIP_AUTHORIZATION_KEY=
SINCH_PROJECT_ID=
SINCH_APP_ID=
SINCH_REGION=us
SINCH_ACCESS_TOKEN=
SINCH_CHANNEL=WHATSAPP
SINCH_API_MODE=conversation
SINCH_SERVICE_NUMBER=
SINCH_SERVICE_USERNAME=
SINCH_SERVICE_TOKEN=
SINCH_API_URL=https://api-messaging.wavy.global/v1/whatsapp/send
CANVAS_FLOW_SINCH_API_URL=
