# ============================================================
# Canvas Flow Backend - production hardening example
# ============================================================
# Copy to the secret manager or deploy environment for real production.
# Do not commit real tokens, connection strings, or API keys.

PORT=3333
NODE_ENV=production
TZ=America/Sao_Paulo

MONGO_DB_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_SERVER_SELECTION_TIMEOUT_MS=8000
MONGO_CONNECT_TIMEOUT_MS=8000

CORS_ORIGINS=https://canvas-flow.example.com
REQUEST_BODY_LIMIT=2mb
ENABLE_SWAGGER=false
CANVAS_FLOW_STRICT_PRODUCTION=true

# Strong secrets. Use different values for each environment.
CANVAS_FLOW_API_TOKEN=<64+_random_chars>
CANVAS_FLOW_JWT_SECRET=<64+_random_chars>
CANVAS_FLOW_MEDIA_PROXY_SECRET=<64+_random_chars>

# Prefer login=true for any public admin UI.
CANVAS_FLOW_LOGIN=true
CANVAS_FLOW_LOGIN_TTL_HOURS=12

# Public URL used for callbacks, signed media links, and webhook docs.
CANVAS_FLOW_PUBLIC_URL=https://api.canvas-flow.example.com
CANVAS_FLOW_API_PUBLIC_URL=https://api.canvas-flow.example.com
PUBLIC_API_URL=https://api.canvas-flow.example.com
APP_URL=https://api.canvas-flow.example.com

# Store original uploads and generated document versions in a private S3 bucket.
CANVAS_FLOW_FILES_STORAGE=s3
CANVAS_FLOW_FILES_S3_BUCKET=<private_s3_bucket>
CANVAS_FLOW_FILES_S3_REGION=us-east-1
CANVAS_FLOW_FILES_DOWNLOAD_TTL_SECONDS=900

# Production rate limits and dedupe.
CANVAS_FLOW_RATE_LIMIT_ENABLED=true
CANVAS_FLOW_RATE_LIMIT_WINDOW_MS=60000
CANVAS_FLOW_RATE_LIMIT_PER_MINUTE=600
CANVAS_FLOW_RATE_LIMIT_WEBWIDGET_PER_MINUTE=300
CANVAS_FLOW_RATE_LIMIT_WHATSAPP_PER_MINUTE=600
CANVAS_FLOW_RATE_LIMIT_API_PER_MINUTE=600
CANVAS_FLOW_MESSAGE_DEDUPE_TTL_HOURS=24

# Async queue. In Lambda, these are normally injected by serverless outputs.
CANVAS_FLOW_SQS=true
CANVAS_FLOW_SQS_QUEUE_URL=<sqs_queue_url>
CANVAS_FLOW_SQS_QUEUE_ARN=<sqs_queue_arn>
CANVAS_FLOW_SQS_REGION=us-east-1
CANVAS_FLOW_SQS_TRIGGER_ENABLED=true
CANVAS_FLOW_SQS_BATCH_SIZE=10
CANVAS_FLOW_SQS_BATCH_WINDOW_SECONDS=2
CANVAS_FLOW_SQS_JOB_TTL_HOURS=24
CANVAS_FLOW_SQS_CONSUMER_CONCURRENCY=10
CANVAS_FLOW_SQS_CONVERSATION_LOCK_TTL_MS=900000

# LangGraph checkpoints. Keep TTL longer than the longest human approval window.
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_NAMESPACE=canvas-flow-runtime-v1
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_COLLECTION=canvas_langgraph_checkpoints
CANVAS_FLOW_LANGGRAPH_WRITES_COLLECTION=canvas_langgraph_checkpoint_writes
CANVAS_FLOW_LANGGRAPH_CHECKPOINT_TTL_HOURS=720

# Lambda normally should not run the internal interval scanner.
CANVAS_FLOW_CRON_AUTORUN=false
CANVAS_FLOW_CRON_SCAN_MS=30000

# Execution guardrails.
CANVAS_FLOW_MAX_PARALLEL_NODES=30
CANVAS_FLOW_MAX_STEP_VISITS=10
CANVAS_FLOW_PROVIDER_CACHE_MS=10000
HTTP_BATCH_TIMEOUT_MS=120000
HTTP_BATCH_MAX_REQUESTS=10
HTTP_BATCH_POLLING_MAX_ATTEMPTS=20
HTTP_BATCH_POLLING_MAX_INTERVAL_SECONDS=60
HTTP_BATCH_POLLING_HISTORY_LIMIT=8

# Optional: managed AWS MCP Server for infrastructure access.
# Prefer a scoped IAM role from the runtime. Do not store AWS credentials in flow JSON.
AWS_REGION=us-east-1
CANVAS_FLOW_AWS_MCP_TARGET_REGION=us-east-1
# CANVAS_FLOW_AWS_MCP_SIGNING_REGION=us-east-1
# CANVAS_FLOW_AWS_MCP_SIGNING_SERVICE=aws-mcp

# LLM/RAG providers. Prefer configuring via the Providers UI when possible.
OPENAI_PROVIDER=openai
OPENAI_API_KEY=<openai_api_key>
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_OCR_MODEL=gpt-4o

AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_API_CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=
AZURE_OPENAI_OCR_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072

MILVUS_ADDRESS=<zilliz_or_milvus_host>
MILVUS_TOKEN=<milvus_token>
MILVUS_USERNAME=
MILVUS_PASSWORD=
COLLECTION_NAME=canvas_flow_docs

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_API_VERSION=2024-07-01

AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=

MONGO_COMPONENT_CONNECTION_STRING=
MONGO_COMPONENT_DB_NAME=
