# ============================================================
# Canvas Flow Frontend - .env.example
# ============================================================
# Apenas variaveis VITE_* entram no bundle do navegador.
# Nunca coloque segredos reais no frontend publico.

# ============================================================
# REQUIRED
# ============================================================
# URL base do backend.
# Em producao na AWS, use a Lambda Function URL do backend.
# Deve apontar para a mesma URL publica usada em CANVAS_FLOW_PUBLIC_URL no backend.
# Exemplo: https://abcxyz.lambda-url.us-east-1.on.aws
VITE_CANVAS_FLOW_API_URL=http://localhost:3333

# Deve refletir CANVAS_FLOW_LOGIN do backend.
VITE_CANVAS_FLOW_LOGIN=false

# ============================================================
# CONDICIONAL
# ============================================================
# Token master para chamadas administrativas quando o backend exige token
# e o login esta desligado. Use somente em ambiente privado/admin.
# Em frontend publico com login ativo, deixe vazio.
VITE_CANVAS_FLOW_API_TOKEN=
